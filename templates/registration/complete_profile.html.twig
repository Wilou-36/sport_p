{% extends 'base.html.twig' %}

{% block title %}Compléter le profil{% endblock %}

{% block body %}
<div class="auth-page">
    <div class="auth-container">
        <div class="auth-card">

            <h2>Compléter votre profil</h2>

            <form method="post">

                {% if 'ROLE_CLIENT' in app.user.roles %}

                    <div class="mb-3">
                        <label for="sport">Sport</label>
                        <select name="sport_id" id="sport" class="form-control" required>
                            <option value="">-- Choisir un sport --</option>
                            {% for sport in sports %}
                                <option value="{{ sport.id }}">
                                    {{ sport.nom }}
                                </option>
                            {% endfor %}
                        </select>
                    </div>

                    <div class="mb-3">
                        <label>Âge</label>
                        <input type="number" name="age" class="form-control" required>
                    </div>

                    <div class="mb-3">
                        <label>Téléphone</label>
                        <input type="text" name="telephone" class="form-control">
                    </div>

                    <div class="mb-3">
                        <label>Taille (m)</label>
                        <input type="number" step="0.01" name="taille" class="form-control">
                    </div>

                    <div class="mb-3">
                        <label>Poids (kg)</label>
                        <input type="number" step="0.01" name="poids" class="form-control">
                    </div>

                {% endif %}

                {% if 'ROLE_COACH' in app.user.roles %}

                    <div class="mb-3">
                        <label>Spécialité</label>
                        <input type="text" name="specialite" class="form-control" required>
                    </div>

                    <div class="mb-3">
                        <label>Années d'expérience</label>
                        <input type="text" name="experience" class="form-control">
                    </div>

                {% endif %}

                <div class="d-flex justify-content-between mt-4">

                    <a href="{{ path('choose_role') }}" class="btn btn-outline-secondary">
                        ← Retour
                    </a>

                    <button type="submit" class="btn btn-primary">
                        Finaliser →
                    </button>

                </div>

            </form>

        </div>
    </div>
</div>
{% endblock %}