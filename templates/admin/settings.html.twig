{% extends 'dashboard/admin.html.twig' %}

{% block admin_content %}

<div class="admin-panel">

    <div class="admin-header">
        <div>
            <h2 class="admin-title">Paramètres Administrateur</h2>
            <p class="admin-subtitle">Gestion de votre compte et des autorisations</p>
        </div>

        <div class="admin-role-badge 
            {% if admin.ctrlAdmin %}
                admin-role-super
            {% else %}
                admin-role-standard
            {% endif %}
        ">
            {% if admin.ctrlAdmin %}
                Administrateur Principal
            {% else %}
                Administrateur
            {% endif %}
        </div>
    </div>


    <form method="post" class="admin-form-card">

        <div class="admin-section">

            <h3 class="admin-section-title">Informations personnelles</h3>

            <div class="admin-grid">

                <div class="admin-input-group">
                    <label>Nom</label>
                    <input type="text" name="nom" value="{{ admin.nom }}" required>
                </div>

                <div class="admin-input-group">
                    <label>Prénom</label>
                    <input type="text" name="prenom" value="{{ admin.prenom }}" required>
                </div>

            </div>

        </div>


        {% if admin.ctrlAdmin %}

        <div class="admin-section admin-advanced-section">

            <h3 class="admin-section-title">Paramètres avancés</h3>

            <div class="admin-input-group">
                <label>Email</label>
                <input type="email" name="email" value="{{ admin.email }}">
            </div>

            <div class="admin-switch-group">
                <label>
                    <input type="checkbox" name="is_verified"
                        {{ admin.isVerified ? 'checked' }}>
                    Compte vérifié
                </label>
            </div>

            <div class="admin-switch-group">
                <label>
                    <input type="checkbox" name="must_change_password"
                        {{ admin.mustChangePassword ? 'checked' }}>
                    Forcer changement de mot de passe
                </label>
            </div>

        </div>

        {% endif %}


        <div class="admin-section">

            <h3 class="admin-section-title">Sécurité</h3>

            <div class="admin-input-group">
                <label>Nouveau mot de passe</label>
                <input type="password" 
                    name="new_password" 
                    id="new_password"
                    placeholder="Nouveau mot de passe">
            </div>

            <div class="admin-input-group">
                <label>Confirmer le mot de passe</label>
                <input type="password" 
                    name="confirm_password" 
                    id="confirm_password"
                    placeholder="Confirmer le mot de passe">
            </div>

            <small id="password-error" class="admin-error-message"></small>

        </div>

        <div class="admin-actions">
            <button type="submit" class="admin-btn-primary">
                Enregistrer les modifications
            </button>
        </div>

    </form>

</div>

{% endblock %}