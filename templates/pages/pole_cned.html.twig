{% extends 'base.html.twig' %}

{% block title %}Sport Pro Performance{% endblock %}

{% block body %}

<div class="page-container">

    <section class="section">
        <h1>Option Football – Le Monde de l'Entreprise</h1>
        <h2>L’excellence sportive au cœur du projet football</h2>

        <p>
            L’option football offre un cadre structurant qui permet aux jeunes de développer pleinement leur potentiel athlétique.
            En s’appuyant sur des entraînements réguliers, un suivi individualisé et la participation à des compétitions de haut niveau,
            l’objectif est de former des joueurs techniquement, tactiquement et mentalement solides.
        </p>

        <h3>Objectifs :</h3>
        <ul class="custom-list">
            <li><strong>Amélioration des compétences footballistiques</strong></li>
            <li><strong>Travail sur la rigueur et le dépassement de soi</strong></li>
            <li><strong>Détection et accompagnement des talents</strong></li>
        </ul>
    </section>


    <section class="section">
        <h2>Un avenir professionnel et personnel sécurisé</h2>

        <p>
            Le football peut être un tremplin, mais il ne doit jamais être le seul projet.
            Nous construisons un double projet pour chaque élève.
        </p>

        <ul class="custom-list">
            <li><strong>Aménagement des emplois du temps</strong></li>
            <li><strong>Partenariat avec le CNED</strong></li>
            <li><strong>Suivi scolaire individualisé</strong></li>
            <li><strong>Ateliers d’orientation professionnelle</strong></li>
            <li><strong>Développement personnel</strong></li>
        </ul>
    </section>


    <section class="section">
        <h2>Un ancrage éducatif fort</h2>

        <p>
            L’option football est un <strong>cadre éducatif exigeant et structurant</strong>,
            intégrant notamment des dispositifs comme le CNED.
        </p>

        <a href="https://www.cned.fr/" class="external-link" target="_blank">
            En savoir plus sur le CNED
        </a>
    </section>


    <section class="section">
        <h2>Fiche programme</h2>

        <div class="table-container">
            <table class="styled-table">
                <thead>
                    <tr>
                        <th>Elément</th>
                        <th>Contenue proposé</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <th >Format</th>
                        <td>Année scolaire complète (septembre à juin), avec un suivi hebdomadaire</td>
                    </tr>
                    <tr>
                        <th>Rythme hebdomadaire</th>
                        <td>15h - 18h de cours CNED (travail encadré et individuel) + 20h d'entraînement sportif + 2h de découverte métier</td>
                    </tr>
                    <tr>
                        <th>Entraînements</th>
                        <td>Séances techniques, tactiques, préparation physique, développement athlétique, matchs internes, coaching mental</td>
                    </tr>
                    <tr>
                        <th>Découverte métiers</th>
                        <td>2h par semaine : atelier avec professionnels, visites d'entreprises, interventions d'orientation scolaire et professionnel</td>
                    </tr>
                    <tr>
                        <th>Encadrement scolaire</th>
                        <td>Tuteur CNED dédié, soutien scolaire individualisé, coaching en méthodes de travail</td>
                    </tr>
                    <tr>
                        <th>Objectif pédagogique</th>
                        <td>réussir le Brevet ou Baccalauréat tout en suivant un Rythme d'athlète de haut niveau</td>
                    </tr>
                    <tr>
                        <th>Objectif sportif</th>
                        <td>Dévolopper des compétences technico-tactiques, physiques, athlétiques et mentales dans un cadre structuré et exigeant</td>
                    </tr>
                
                </tbody>
            </table>
        </div>
    </section>


    <section class="section">
        <h2>Emploi du temps type</h2>

        <div class="table-container">
            <table class="styled-table">
                <thead>
                    <tr>
                    <th>Journée</th>
                    <th>Matin</th>
                    <th>Après-midi</th>
                    <th>Fin de journée</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <th>Lundi</th>
                        <td>CNED encadré (3h)</td>
                        <td>Entraînement technico-tactique (2h)</td>
                        <td>Etude / soutien scolaire</td>
                    </tr>
                    <tr>
                        <td>Mardi</th>
                        <td>CNED individuel (2h)</td>
                        <td>Préparation physique + Ateliers tactiques (2h)</td>
                        <td>coaching mental (1h)</td>
                    </tr>
                    <tr>
                        <th>Mercredi</th>
                        <td>CNED encadré (2h)</td>
                        <td>Match interne ou jeu dirigé (2h)</td>
                        <td>Temps libre / récupération</td>
                    </tr>
                    <tr>
                        <th>Jeudi</th>
                        <td>CNED individuel (3h)</td>
                        <td>entraînement intensif + vidéo (2h)</td>
                        <td>découverte métier (1h)</td>
                    </tr>
                    <tr>
                        <th>Vendredi</th>
                        <td>CNED encadré (2h)</td>
                        <td>Préparation physique + atelier métiers (2h)</td>
                        <td>Bilan individuel (1h)</td>
                    </tr>
                    <tr>
                        <th>Samedi</th>
                        <td>Match ou tournoi</td>
                        <td>Récupération active (étirements, gainage)</td>
                        <td></td>
                    </tr>
                    <tr>
                        <th>Dimanche</td>
                        <td>Repos ou travail personnel</td>
                        <td></td>
                        <td></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </section>


    <section class="section">
        <h2>Les partenariats</h2>

        <div class="table-container">
            <table class="styled-table">
                 <thead>
          <tr>
            <th>Type de partenaire</th>
            <th>Rôle & Contribution </th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <th >CNED</th>
            <td>Fournisseur des cours officiels pour Brevets et Baccalauréat - plateforme et suivi</td>
          </tr>
          <tr>
            <th>Professeurs/tuteurs CNED</th>
            <td>Accompagnement hebdomadaire des élèves, soutien aux devoirs et méthodologie</td>
          </tr>
          <tr>
            <th>Encadrements sportifs SPP</th>
            <td>Coachs diplomés en football (UEFA, BEF,...) - suivi technico-tactique et physique</td>
          </tr>
          <tr>
            <th>Préparateur mental</th>
            <td>Développement de la concentration, de la gestion du stress et de la motivation</td>
          </tr>
          <tr>
            <th>professionnels métiers</th>
            <td>interventions sur la découverte de métiers - témoignages, mini-ateliers</td>
          </tr>
          <tr>
            <th>Structures d'accueil(clubs)</th>
            <td>Acceuil ponctuel de jeunes pour observations ou stages sportifs</td>
          </tr>
          <tr>
            <th>Parent / Familles</th>
            <td>Partenaires éducatifs essentiels - suivi des progrès et relai motivation</td>
          </tr>
          
        </tbody>
            </table>
        </div>
    </section>

</div>

{% endblock %}
